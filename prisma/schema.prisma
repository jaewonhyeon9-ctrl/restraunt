generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 사업장
model Restaurant {
  id         String   @id @default(cuid())
  name       String
  address    String?
  lat        Float?
  lng        Float?
  gpsRadius  Int      @default(50)
  plan       Plan     @default(FREE)
  createdAt  DateTime @default(now())

  users            User[]
  checklistTemplates ChecklistTemplate[]
  suppliers        Supplier[]
  inventoryItems   InventoryItem[]
  purchaseOrders   PurchaseOrder[]
  receiptImages    ReceiptImage[]
  expenses         Expense[]
  fixedExpenses    FixedExpense[]
  sales            Sale[]
  dailyReports     DailyReport[]
  notifications    Notification[]
  attendance       Attendance[]
  checklistLogs    ChecklistLog[]
  inventoryLogs    InventoryLog[]
  dailyNotes       DailyNote[]
  ocrUsages        OcrUsage[]
  menus            Menu[]
  members          UserRestaurant[] @relation("RestaurantMembers")
}

// 메뉴 (판매 단위)
model Menu {
  id           String   @id @default(cuid())
  restaurantId String
  name         String
  price        Float    // 판매가
  category     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  recipes    MenuRecipe[]
  saleItems  SaleItem[]

  @@index([restaurantId, isActive])
}

// 메뉴-재고 매핑 (레시피)
// 메뉴 1개 판매 시 사용되는 재고 항목과 수량
model MenuRecipe {
  id              String  @id @default(cuid())
  menuId          String
  inventoryItemId String
  qtyUsed         Float   // 메뉴 1개당 사용량 (재고 unit 기준)

  menu          Menu          @relation(fields: [menuId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@unique([menuId, inventoryItemId])
  @@index([menuId])
}

// 매출 항목 (한 매출 안의 메뉴별 판매 내역, OCR로부터 추출)
model SaleItem {
  id        String   @id @default(cuid())
  saleId    String
  menuId    String?  // 매핑된 메뉴 (없으면 자유 입력)
  rawName   String   // OCR 원문 또는 메뉴명
  qty       Int
  unitPrice Float
  subtotal  Float
  costAtSale Float?  // 판매 시점 원가 스냅샷 (원가 변동 후에도 보존)
  createdAt DateTime @default(now())

  sale Sale  @relation(fields: [saleId], references: [id], onDelete: Cascade)
  menu Menu? @relation(fields: [menuId], references: [id])

  @@index([saleId])
  @@index([menuId])
}

enum Plan {
  FREE
  STANDARD
  PRO
}

// OCR 월별 사용량 집계 (플랜별 월 한도 체크용)
model OcrUsage {
  id            String   @id @default(cuid())
  restaurantId  String
  yearMonth     String   // "2026-04"
  count         Int      @default(0)
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, yearMonth])
  @@index([restaurantId])
}

// 사용자-매장 다대다 연결 (다점포 사장/매니저 지원)
model UserRestaurant {
  id           String   @id @default(cuid())
  userId       String
  restaurantId String
  role         Role     @default(OWNER)
  isPrimary    Boolean  @default(false)  // 주 매장 (가입 시 자동 매장)
  joinedAt     DateTime @default(now())

  user       User       @relation("UserAccessRestaurants", fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation("RestaurantMembers", fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([userId, restaurantId])
  @@index([userId])
  @@index([restaurantId])
}

// 사용자 (사장 + 직원)
model User {
  id                 String     @id @default(cuid())
  restaurantId       String     // 주 매장 (가입 시점)
  activeRestaurantId String?    // 현재 작업 중인 매장 (다점포 사장이 전환 가능)
  email              String     @unique
  passwordHash       String
  name               String
  role               Role       @default(EMPLOYEE)
  phone              String?
  hourlyWage         Float?
  monthlyWage        Float?
  hireDate           DateTime?
  isActive           Boolean    @default(true)
  createdAt          DateTime   @default(now())

  restaurant         Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  attendance         Attendance[]
  checklistLogs      ChecklistLog[]
  requestedOrders    PurchaseOrder[]  @relation("RequestedBy")
  approvedOrders     PurchaseOrder[]  @relation("ApprovedBy")
  receiptImages      ReceiptImage[]
  expenses           Expense[]
  sales              Sale[]
  inventoryLogs      InventoryLog[]
  notifications      Notification[]
  dailyNotes         DailyNote[]
  kakaoIntegration   KakaoIntegration?
  restaurantAccess   UserRestaurant[] @relation("UserAccessRestaurants")
}

// 카카오톡 연동 (나에게 보내기 자동 발송)
model KakaoIntegration {
  id                 String   @id @default(cuid())
  userId             String   @unique
  kakaoId            String
  accessToken        String   @db.Text
  refreshToken       String   @db.Text
  expiresAt          DateTime
  dailyReportEnabled Boolean  @default(true)
  sendHour           Int      @default(23)
  lastSentAt         DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  OWNER
  EMPLOYEE
}

// 출퇴근 기록
model Attendance {
  id           String    @id @default(cuid())
  userId       String
  restaurantId String
  date         DateTime  @db.Date
  clockIn      DateTime?
  clockOut     DateTime?
  clockInLat   Float?
  clockInLng   Float?
  clockOutLat  Float?
  clockOutLng  Float?
  workMinutes  Int?
  dailyWage    Float?
  note         String?
  createdAt    DateTime  @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@unique([userId, date])
}

// 체크리스트 카테고리 (주방/서빙)
enum ChecklistCategory {
  KITCHEN
  HALL
}

// 체크리스트 템플릿
model ChecklistTemplate {
  id            String            @id @default(cuid())
  restaurantId  String
  title         String
  description   String?
  assignedRole  Role              @default(EMPLOYEE)
  category      ChecklistCategory @default(HALL)
  timeSlot      String?
  scheduledTime String?           // "HH:mm" 형식 (예: "09:30")
  sortOrder     Int               @default(0)
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())

  restaurant    Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  checklistLogs ChecklistLog[]
}

// 체크리스트 실행 로그
model ChecklistLog {
  id           String    @id @default(cuid())
  templateId   String
  userId       String
  restaurantId String
  date         DateTime  @db.Date
  checkedAt    DateTime?
  isChecked    Boolean   @default(false)
  note         String?
  createdAt    DateTime  @default(now())

  template   ChecklistTemplate @relation(fields: [templateId], references: [id])
  user       User              @relation(fields: [userId], references: [id])
  restaurant Restaurant        @relation(fields: [restaurantId], references: [id])

  @@unique([templateId, userId, date])
}

// 일일 메모 타입 (교대 전달/특이사항/사장 전달/컴플레인)
enum DailyNoteType {
  HANDOVER     // 다음 타임 전달사항
  ANOMALY      // 특이사항
  OWNER_NOTE   // 사장님께 전달사항
  COMPLAINT    // 고객 컴플레인
}

// 일일 메모 (체크리스트 하단 입력 항목)
model DailyNote {
  id           String        @id @default(cuid())
  restaurantId String
  userId       String
  date         DateTime      @db.Date
  type         DailyNoteType
  category     ChecklistCategory?
  content      String
  createdAt    DateTime      @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])

  @@index([restaurantId, date])
}

// 거래처
model Supplier {
  id           String   @id @default(cuid())
  restaurantId String
  name         String
  contactName  String?
  phone        String?
  email        String?
  category     String?
  paymentDay   Int?
  note         String?
  createdAt    DateTime @default(now())

  restaurant     Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  inventoryItems InventoryItem[]
  purchaseOrders PurchaseOrder[]
  expenses       Expense[]
}

// 재고 마스터
model InventoryItem {
  id           String   @id @default(cuid())
  restaurantId String
  supplierId   String?
  name         String
  unit         String
  unitPrice    Float?
  safetyStock  Float?
  currentStock Float    @default(0)
  category     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  restaurant     Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  supplier       Supplier?           @relation(fields: [supplierId], references: [id])
  inventoryLogs  InventoryLog[]
  orderItems     PurchaseOrderItem[]
  recipes        MenuRecipe[]
}

// 재고 변동 이력
model InventoryLog {
  id           String           @id @default(cuid())
  itemId       String
  restaurantId String
  userId       String
  type         InventoryLogType
  quantity     Float
  beforeStock  Float?
  afterStock   Float?
  unitPrice    Float?
  totalPrice   Float?
  note         String?
  expenseId    String?
  createdAt    DateTime         @default(now())

  item       InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  restaurant Restaurant    @relation(fields: [restaurantId], references: [id])
  user       User          @relation(fields: [userId], references: [id])
}

enum InventoryLogType {
  IN
  OUT
  ADJUST
  ORDER_IN
}

// 발주
model PurchaseOrder {
  id            String              @id @default(cuid())
  restaurantId  String
  supplierId    String?
  requestedById String
  approvedById  String?
  orderDate     DateTime            @db.Date
  expectedDate  DateTime?           @db.Date
  status        PurchaseOrderStatus @default(PENDING)
  totalAmount   Float?
  note          String?
  createdAt     DateTime            @default(now())

  restaurant   Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  supplier     Supplier?           @relation(fields: [supplierId], references: [id])
  requestedBy  User                @relation("RequestedBy", fields: [requestedById], references: [id])
  approvedBy   User?               @relation("ApprovedBy", fields: [approvedById], references: [id])
  items        PurchaseOrderItem[]
}

enum PurchaseOrderStatus {
  PENDING
  APPROVED
  ORDERED
  RECEIVED
  CANCELLED
}

// 발주 상세
model PurchaseOrderItem {
  id         String  @id @default(cuid())
  orderId    String
  itemId     String?
  itemName   String
  quantity   Float
  unit       String
  unitPrice  Float?
  totalPrice Float?

  order PurchaseOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  item  InventoryItem? @relation(fields: [itemId], references: [id])
}

// 영수증 이미지
model ReceiptImage {
  id           String        @id @default(cuid())
  restaurantId String
  userId       String
  imageUrl     String
  ocrRawText   String?
  ocrParsed    Json?
  status       ReceiptStatus @default(PENDING)
  createdAt    DateTime      @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  user       User       @relation(fields: [userId], references: [id])
  expenses   Expense[]
}

enum ReceiptStatus {
  PENDING
  PROCESSED
  CONFIRMED
  FAILED
}

// 지출
model Expense {
  id             String          @id @default(cuid())
  restaurantId   String
  userId         String
  supplierId     String?
  receiptId      String?
  category       ExpenseCategory
  amount         Float
  expenseDate    DateTime        @db.Date
  description    String?
  isFixed        Boolean         @default(false)
  fixedExpenseId String?
  // 세무: 매입세액공제 여부 + 증빙 유형
  isVatDeductible Boolean        @default(true)
  receiptType    ReceiptType     @default(NONE)
  createdAt      DateTime        @default(now())

  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id])
  supplier     Supplier?     @relation(fields: [supplierId], references: [id])
  receiptImage ReceiptImage? @relation(fields: [receiptId], references: [id])
  fixedExpense FixedExpense? @relation(fields: [fixedExpenseId], references: [id])
}

enum ExpenseCategory {
  INGREDIENT
  UTILITY
  WAGE
  RENT
  EQUIPMENT
  OTHER
}

enum ReceiptType {
  TAX_INVOICE   // 세금계산서
  CARD          // 신용카드/체크카드 매입전표
  CASH_RECEIPT  // 현금영수증(사업자)
  SIMPLE        // 간이영수증(공제불가)
  NONE          // 증빙없음
}

// 고정지출 마스터
model FixedExpense {
  id           String          @id @default(cuid())
  restaurantId String
  name         String
  category     ExpenseCategory
  amount       Float
  billingDay   Int?
  isDailyCalc  Boolean         @default(false)
  userId       String?
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  expenses   Expense[]
}

// 매출
model Sale {
  id             String   @id @default(cuid())
  restaurantId   String
  userId         String
  saleDate       DateTime @db.Date
  amount         Float
  cashAmount     Float    @default(0)
  cardAmount     Float    @default(0)
  deliveryAmount Float    @default(0)
  note           String?
  createdAt      DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])
  items      SaleItem[]

  @@unique([restaurantId, saleDate])
}

// 일일 손익 리포트
model DailyReport {
  id             String   @id @default(cuid())
  restaurantId   String
  reportDate     DateTime @db.Date
  totalSales     Float    @default(0)
  totalExpenses  Float    @default(0)
  ingredientCost Float    @default(0)
  wageCost       Float    @default(0)
  fixedCost      Float    @default(0)
  otherCost      Float    @default(0)
  netProfit      Float    @default(0)
  profitMargin   Float?
  createdAt      DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, reportDate])
}

// 알림
model Notification {
  id            String   @id @default(cuid())
  restaurantId  String
  userId        String?
  type          String
  title         String
  message       String?
  referenceId   String?
  referenceType String?
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  user       User?      @relation(fields: [userId], references: [id])
}
