generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 사업장
model Restaurant {
  id         String   @id @default(cuid())
  name       String
  address    String?
  lat        Float?
  lng        Float?
  gpsRadius  Int      @default(50)
  createdAt  DateTime @default(now())

  users            User[]
  checklistTemplates ChecklistTemplate[]
  suppliers        Supplier[]
  inventoryItems   InventoryItem[]
  purchaseOrders   PurchaseOrder[]
  receiptImages    ReceiptImage[]
  expenses         Expense[]
  fixedExpenses    FixedExpense[]
  sales            Sale[]
  dailyReports     DailyReport[]
  notifications    Notification[]
  attendance       Attendance[]
  checklistLogs    ChecklistLog[]
  inventoryLogs    InventoryLog[]
  dailyNotes       DailyNote[]
}

// 사용자 (사장 + 직원)
model User {
  id            String     @id @default(cuid())
  restaurantId  String
  email         String     @unique
  passwordHash  String
  name          String
  role          Role       @default(EMPLOYEE)
  phone         String?
  hourlyWage    Float?
  monthlyWage   Float?
  hireDate      DateTime?
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())

  restaurant       Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  attendance       Attendance[]
  checklistLogs    ChecklistLog[]
  requestedOrders  PurchaseOrder[] @relation("RequestedBy")
  approvedOrders   PurchaseOrder[] @relation("ApprovedBy")
  receiptImages    ReceiptImage[]
  expenses         Expense[]
  sales            Sale[]
  inventoryLogs    InventoryLog[]
  notifications    Notification[]
  dailyNotes       DailyNote[]
  kakaoIntegration KakaoIntegration?
}

// 카카오톡 연동 (나에게 보내기 자동 발송)
model KakaoIntegration {
  id                 String   @id @default(cuid())
  userId             String   @unique
  kakaoId            String
  accessToken        String   @db.Text
  refreshToken       String   @db.Text
  expiresAt          DateTime
  dailyReportEnabled Boolean  @default(true)
  sendHour           Int      @default(23)
  lastSentAt         DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  OWNER
  EMPLOYEE
}

// 출퇴근 기록
model Attendance {
  id           String    @id @default(cuid())
  userId       String
  restaurantId String
  date         DateTime  @db.Date
  clockIn      DateTime?
  clockOut     DateTime?
  clockInLat   Float?
  clockInLng   Float?
  clockOutLat  Float?
  clockOutLng  Float?
  workMinutes  Int?
  dailyWage    Float?
  note         String?
  createdAt    DateTime  @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@unique([userId, date])
}

// 체크리스트 카테고리 (주방/서빙)
enum ChecklistCategory {
  KITCHEN
  HALL
}

// 체크리스트 템플릿
model ChecklistTemplate {
  id            String            @id @default(cuid())
  restaurantId  String
  title         String
  description   String?
  assignedRole  Role              @default(EMPLOYEE)
  category      ChecklistCategory @default(HALL)
  timeSlot      String?
  scheduledTime String?           // "HH:mm" 형식 (예: "09:30")
  sortOrder     Int               @default(0)
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())

  restaurant    Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  checklistLogs ChecklistLog[]
}

// 체크리스트 실행 로그
model ChecklistLog {
  id           String    @id @default(cuid())
  templateId   String
  userId       String
  restaurantId String
  date         DateTime  @db.Date
  checkedAt    DateTime?
  isChecked    Boolean   @default(false)
  note         String?
  createdAt    DateTime  @default(now())

  template   ChecklistTemplate @relation(fields: [templateId], references: [id])
  user       User              @relation(fields: [userId], references: [id])
  restaurant Restaurant        @relation(fields: [restaurantId], references: [id])

  @@unique([templateId, userId, date])
}

// 일일 메모 타입 (교대 전달/특이사항/사장 전달/컴플레인)
enum DailyNoteType {
  HANDOVER     // 다음 타임 전달사항
  ANOMALY      // 특이사항
  OWNER_NOTE   // 사장님께 전달사항
  COMPLAINT    // 고객 컴플레인
}

// 일일 메모 (체크리스트 하단 입력 항목)
model DailyNote {
  id           String        @id @default(cuid())
  restaurantId String
  userId       String
  date         DateTime      @db.Date
  type         DailyNoteType
  category     ChecklistCategory?
  content      String
  createdAt    DateTime      @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])

  @@index([restaurantId, date])
}

// 거래처
model Supplier {
  id           String   @id @default(cuid())
  restaurantId String
  name         String
  contactName  String?
  phone        String?
  email        String?
  category     String?
  paymentDay   Int?
  note         String?
  createdAt    DateTime @default(now())

  restaurant     Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  inventoryItems InventoryItem[]
  purchaseOrders PurchaseOrder[]
  expenses       Expense[]
}

// 재고 마스터
model InventoryItem {
  id           String   @id @default(cuid())
  restaurantId String
  supplierId   String?
  name         String
  unit         String
  unitPrice    Float?
  safetyStock  Float?
  currentStock Float    @default(0)
  category     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  restaurant     Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  supplier       Supplier?           @relation(fields: [supplierId], references: [id])
  inventoryLogs  InventoryLog[]
  orderItems     PurchaseOrderItem[]
}

// 재고 변동 이력
model InventoryLog {
  id           String           @id @default(cuid())
  itemId       String
  restaurantId String
  userId       String
  type         InventoryLogType
  quantity     Float
  beforeStock  Float?
  afterStock   Float?
  unitPrice    Float?
  totalPrice   Float?
  note         String?
  expenseId    String?
  createdAt    DateTime         @default(now())

  item       InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  restaurant Restaurant    @relation(fields: [restaurantId], references: [id])
  user       User          @relation(fields: [userId], references: [id])
}

enum InventoryLogType {
  IN
  OUT
  ADJUST
  ORDER_IN
}

// 발주
model PurchaseOrder {
  id            String              @id @default(cuid())
  restaurantId  String
  supplierId    String?
  requestedById String
  approvedById  String?
  orderDate     DateTime            @db.Date
  expectedDate  DateTime?           @db.Date
  status        PurchaseOrderStatus @default(PENDING)
  totalAmount   Float?
  note          String?
  createdAt     DateTime            @default(now())

  restaurant   Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  supplier     Supplier?           @relation(fields: [supplierId], references: [id])
  requestedBy  User                @relation("RequestedBy", fields: [requestedById], references: [id])
  approvedBy   User?               @relation("ApprovedBy", fields: [approvedById], references: [id])
  items        PurchaseOrderItem[]
}

enum PurchaseOrderStatus {
  PENDING
  APPROVED
  ORDERED
  RECEIVED
  CANCELLED
}

// 발주 상세
model PurchaseOrderItem {
  id         String  @id @default(cuid())
  orderId    String
  itemId     String?
  itemName   String
  quantity   Float
  unit       String
  unitPrice  Float?
  totalPrice Float?

  order PurchaseOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  item  InventoryItem? @relation(fields: [itemId], references: [id])
}

// 영수증 이미지
model ReceiptImage {
  id           String        @id @default(cuid())
  restaurantId String
  userId       String
  imageUrl     String
  ocrRawText   String?
  ocrParsed    Json?
  status       ReceiptStatus @default(PENDING)
  createdAt    DateTime      @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  user       User       @relation(fields: [userId], references: [id])
  expenses   Expense[]
}

enum ReceiptStatus {
  PENDING
  PROCESSED
  CONFIRMED
  FAILED
}

// 지출
model Expense {
  id             String          @id @default(cuid())
  restaurantId   String
  userId         String
  supplierId     String?
  receiptId      String?
  category       ExpenseCategory
  amount         Float
  expenseDate    DateTime        @db.Date
  description    String?
  isFixed        Boolean         @default(false)
  fixedExpenseId String?
  // 세무: 매입세액공제 여부 + 증빙 유형
  isVatDeductible Boolean        @default(true)
  receiptType    ReceiptType     @default(NONE)
  createdAt      DateTime        @default(now())

  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id])
  supplier     Supplier?     @relation(fields: [supplierId], references: [id])
  receiptImage ReceiptImage? @relation(fields: [receiptId], references: [id])
  fixedExpense FixedExpense? @relation(fields: [fixedExpenseId], references: [id])
}

enum ExpenseCategory {
  INGREDIENT
  UTILITY
  WAGE
  RENT
  EQUIPMENT
  OTHER
}

enum ReceiptType {
  TAX_INVOICE   // 세금계산서
  CARD          // 신용카드/체크카드 매입전표
  CASH_RECEIPT  // 현금영수증(사업자)
  SIMPLE        // 간이영수증(공제불가)
  NONE          // 증빙없음
}

// 고정지출 마스터
model FixedExpense {
  id           String          @id @default(cuid())
  restaurantId String
  name         String
  category     ExpenseCategory
  amount       Float
  billingDay   Int?
  isDailyCalc  Boolean         @default(false)
  userId       String?
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  expenses   Expense[]
}

// 매출
model Sale {
  id             String   @id @default(cuid())
  restaurantId   String
  userId         String
  saleDate       DateTime @db.Date
  amount         Float
  cashAmount     Float    @default(0)
  cardAmount     Float    @default(0)
  deliveryAmount Float    @default(0)
  note           String?
  createdAt      DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])

  @@unique([restaurantId, saleDate])
}

// 일일 손익 리포트
model DailyReport {
  id             String   @id @default(cuid())
  restaurantId   String
  reportDate     DateTime @db.Date
  totalSales     Float    @default(0)
  totalExpenses  Float    @default(0)
  ingredientCost Float    @default(0)
  wageCost       Float    @default(0)
  fixedCost      Float    @default(0)
  otherCost      Float    @default(0)
  netProfit      Float    @default(0)
  profitMargin   Float?
  createdAt      DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, reportDate])
}

// 알림
model Notification {
  id            String   @id @default(cuid())
  restaurantId  String
  userId        String?
  type          String
  title         String
  message       String?
  referenceId   String?
  referenceType String?
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  user       User?      @relation(fields: [userId], references: [id])
}
